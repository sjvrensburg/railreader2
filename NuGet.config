<?xml version="1.0" encoding="utf-8"?>
<!--
  Local source for RailReaderCore 0.5.0. This branch (feat/pp-doclayout-s)
  depends on the PP-DocLayout-S analyzer that lands in RailReaderCore 0.5.0,
  which is not yet on nuget.org as of this commit.

  To build this branch locally, produce the pack from a sibling RailReaderCore
  checkout on its feat/pp-doclayout-s-analyzer branch:

      cd ../RailReaderCore
      dotnet pack RailReaderCore.slnx -c Release -o dist/ -p:Version=0.5.0

  Once RailReaderCore 0.5.0 is published to nuget.org, this file becomes
  optional and can be deleted.
-->
<configuration>
  <packageSources>
    <add key="railreadercore-local" value="../RailReaderCore/dist" />
  </packageSources>
</configuration>
