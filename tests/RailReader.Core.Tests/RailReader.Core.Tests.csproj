<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- PDFtoImage marks APIs as platform-specific -->
    <NoWarn>CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.*" />
    <PackageReference Include="xunit" Version="2.9.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="RailReader.Core" Version="0.1.3" />
    <PackageReference Include="RailReader.Core.Pdfium" Version="0.1.3" />
    <PackageReference Include="RailReader.Core.Analysis" Version="0.1.3" />
    <PackageReference Include="RailReader.Renderer.Skia" Version="0.1.3" />
  </ItemGroup>

</Project>
