<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RailReader2.Views.MinimapControl"
             ClipToBounds="True"
             HorizontalAlignment="Right"
             VerticalAlignment="Bottom"
             Cursor="Hand"
             ToolTip.Tip="Minimap — click to navigate; drag top edge to move; drag corner to resize (Ctrl+M to toggle)">
</UserControl>
