<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="using:Avalonia.Automation"
             xmlns:c="using:RailReader2.Controls"
             x:Class="RailReader2.Views.ToolBarView">
    <UserControl.Styles>
        <!-- Theme-aware compact tool buttons. Icons inherit Foreground (the theme text
             colour), so they adapt to light/dark; active tools use the accent. Buttons
             auto-size to the (FontSize-scaled) icon, so the toolbar grows with the UI. -->
        <Style Selector="ToggleButton.toolBtn, Button.toolBtn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ToggleButton.toolBtn:pointerover, Button.toolBtn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
        </Style>
        <Style Selector="ToggleButton.toolBtn:checked">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="ToggleButton.toolBtn:checked:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.toolBtn:disabled">
            <Setter Property="Opacity" Value="0.4" />
        </Style>
        <Style Selector="Border.toolSep">
            <Setter Property="Width" Value="1" />
            <Setter Property="Margin" Value="3,2" />
            <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="1"
            CornerRadius="5"
            Padding="4,4">
        <StackPanel Orientation="Horizontal" Spacing="4">
            <!-- Always available (reading + mode toggle) -->
            <ToggleButton Name="BrowseButton" Classes="toolBtn" ToolTip.Tip="Browse / Pan"
                          a:AutomationProperties.Name="Browse / Pan">
                <c:Icon Data="{StaticResource IconBrowse}" />
            </ToggleButton>
            <ToggleButton Name="SelectButton" Classes="toolBtn" ToolTip.Tip="Text Select"
                          a:AutomationProperties.Name="Text Select">
                <c:Icon Data="{StaticResource IconTextSelect}" />
            </ToggleButton>
            <Button Name="CopyButton" Classes="toolBtn" ToolTip.Tip="Copy Selected Text (Ctrl+C)"
                    a:AutomationProperties.Name="Copy selected text" IsVisible="False">
                <c:Icon Data="{StaticResource IconCopy}" />
            </Button>

            <Border Classes="toolSep" />

            <ToggleButton Name="AnnotateButton" Classes="toolBtn" ToolTip.Tip="Annotation Mode (Ctrl+E)"
                          a:AutomationProperties.Name="Annotation mode">
                <c:Icon Data="{StaticResource IconAnnotate}" />
            </ToggleButton>

            <!-- Mode-gated annotation tools (shown only in annotation mode) -->
            <StackPanel Name="AnnotationSection" Orientation="Horizontal" Spacing="4" IsVisible="False">
                <Border Classes="toolSep" />

                <!-- Text-markup tools: pick one, then drag over text to apply (sticky) -->
                <ToggleButton Name="HighlightButton" Classes="toolBtn" ToolTip.Tip="Highlight (drag over text)"
                              a:AutomationProperties.Name="Highlight">
                    <c:Icon Data="{StaticResource IconHighlight}" />
                </ToggleButton>
                <ToggleButton Name="UnderlineButton" Classes="toolBtn" ToolTip.Tip="Underline (drag over text)"
                              a:AutomationProperties.Name="Underline">
                    <c:Icon Data="{StaticResource IconUnderline}" />
                </ToggleButton>
                <ToggleButton Name="StrikeButton" Classes="toolBtn" ToolTip.Tip="Strikethrough (drag over text)"
                              a:AutomationProperties.Name="Strikethrough">
                    <c:Icon Data="{StaticResource IconStrikethrough}" />
                </ToggleButton>
                <ToggleButton Name="SquigglyButton" Classes="toolBtn" ToolTip.Tip="Squiggly (drag over text)"
                              a:AutomationProperties.Name="Squiggly underline">
                    <c:Icon Data="{StaticResource IconSquiggly}" />
                </ToggleButton>

                <Border Classes="toolSep" />

                <!-- Drawing / note tools -->
                <ToggleButton Name="PenButton" Classes="toolBtn" ToolTip.Tip="Pen"
                              a:AutomationProperties.Name="Pen">
                    <c:Icon Data="{StaticResource IconPen}" />
                </ToggleButton>
                <ToggleButton Name="RectButton" Classes="toolBtn" ToolTip.Tip="Rectangle"
                              a:AutomationProperties.Name="Rectangle">
                    <c:Icon Data="{StaticResource IconRectangle}" />
                </ToggleButton>
                <ToggleButton Name="NoteButton" Classes="toolBtn" ToolTip.Tip="Text Note (sticky note)"
                              a:AutomationProperties.Name="Text note">
                    <c:Icon Data="{StaticResource IconNote}" />
                </ToggleButton>
                <ToggleButton Name="FreeTextButton" Classes="toolBtn" ToolTip.Tip="Text box (typewriter — drag a box)"
                              a:AutomationProperties.Name="Text box">
                    <c:Icon Data="{StaticResource IconFreeText}" />
                </ToggleButton>
                <ToggleButton Name="EraserButton" Classes="toolBtn" ToolTip.Tip="Eraser"
                              a:AutomationProperties.Name="Eraser">
                    <c:Icon Data="{StaticResource IconEraser}" />
                </ToggleButton>

                <Border Classes="toolSep" />

                <Button Name="ColorButton" Classes="toolBtn" ToolTip.Tip="Colour"
                        a:AutomationProperties.Name="Colour">
                    <Border Name="ColorSwatch" Width="16" Height="16" CornerRadius="2"
                            Background="#FFFF00" BorderBrush="#888888" BorderThickness="1" />
                </Button>
                <Button Name="ThicknessButton" Classes="toolBtn" ToolTip.Tip="Thickness"
                        a:AutomationProperties.Name="Stroke thickness">
                    <c:Icon Data="{StaticResource IconThickness}" />
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
