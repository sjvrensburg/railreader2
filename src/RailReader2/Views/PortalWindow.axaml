<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RailReader2.ViewModels"
        xmlns:ctrl="using:RailReader2.Controls"
        xmlns:a="using:Avalonia.Automation"
        xmlns:conv="using:Avalonia.Data.Converters"
        x:Class="RailReader2.Views.PortalWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="RailReader2 — Portal"
        Width="420" Height="320"
        MinWidth="180" MinHeight="140"
        WindowDecorations="None"
        ShowInTaskbar="True"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    <!-- The window is intentionally dark (figures read well on it), so the chrome controls are
         styled explicitly here rather than inheriting the app theme — otherwise their themed
         foreground/background clashes with the dark bar and the labels become illegible. -->
    <Window.Styles>
        <Style Selector="Button.chrome, ToggleButton.chrome">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#33FFFFFF" />
            <Setter Property="BorderBrush" Value="#66FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,2" />
        </Style>
        <Style Selector="Button.chrome /template/ ContentPresenter, ToggleButton.chrome /template/ ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="Button.chrome:pointerover /template/ ContentPresenter, ToggleButton.chrome:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#55FFFFFF" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="ToggleButton.chrome:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A7BD5" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
    </Window.Styles>
    <Border BorderBrush="#80808080" BorderThickness="1" Background="#1A1A1A">
        <DockPanel>
            <!-- Slim draggable chrome -->
            <!-- Chrome text/icons inherit the font size set by ApplyFontScale (UI font-scale aware);
                 the bar grows with it rather than clipping. -->
            <Border Name="ChromeBar" DockPanel.Dock="Top" Background="#2A2A2A" MinHeight="28"
                    PointerPressed="OnChromePointerPressed">
                <DockPanel Margin="4,0,4,0" LastChildFill="True">
                    <!-- View lock: freeze the shown target against reading-position-driven switching. -->
                    <ToggleButton Classes="chrome" DockPanel.Dock="Left" Margin="0,0,6,0" Padding="5,2"
                                  IsChecked="{Binding IsPortalViewLocked}"
                                  a:AutomationProperties.Name="Lock target"
                                  ToolTip.Tip="Freeze this target: keep showing it while you read on — auto-pins and portal sources won't replace it until unlocked">
                        <Panel>
                            <ctrl:Icon Data="{StaticResource IconLockOpen}" SizeFactor="1.0"
                                    IsVisible="{Binding !IsPortalViewLocked}" />
                            <ctrl:Icon Data="{StaticResource IconLock}" SizeFactor="1.0"
                                    IsVisible="{Binding IsPortalViewLocked}" />
                        </Panel>
                    </ToggleButton>
                    <StackPanel Orientation="Horizontal" Spacing="4" DockPanel.Dock="Right">
                        <ToggleButton Name="TopmostToggle" Classes="chrome" Content="Pin" IsChecked="True"
                                      Click="OnTopmostToggle"
                                      ToolTip.Tip="Keep this window above others (always on top)" />
                        <Button Classes="chrome" Content="Dock" Click="OnDockClick"
                                ToolTip.Tip="Return the portal to the side panel" />
                    </StackPanel>
                    <TextBlock Text="{Binding PortalWindowLabel}" Foreground="White"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </Border>

            <!-- Target crop (peek when one is up, otherwise saved-portal tracking).
                 Zoomable/pannable for dense tables: wheel zooms, drag pans, double-click refits. -->
            <Grid>
                <ctrl:ZoomPanImage Source="{Binding PortalWindowImage}" Margin="4"
                                   ToolTip.Tip="Scroll to zoom, drag to pan, double-click to fit" />
                <TextBlock Text="{Binding PortalWindowHint}" Foreground="#AAAAAA"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="12"
                           IsVisible="{Binding PortalWindowImage, Converter={x:Static conv:ObjectConverters.IsNull}}" />

                <!-- Bottom-right resize grip (borderless windows have no OS resize border) -->
                <Border Name="ResizeGrip" Width="16" Height="16"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Background="Transparent" Cursor="BottomRightCorner"
                        PointerPressed="OnResizePointerPressed">
                    <Path Data="M 14,2 L 14,14 L 2,14" Stroke="#80FFFFFF" StrokeThickness="1.5" />
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
