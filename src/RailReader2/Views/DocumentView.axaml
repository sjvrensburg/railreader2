<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RailReader2.ViewModels"
             xmlns:v="using:RailReader2.Views"
             xmlns:a="using:Avalonia.Automation"
             x:Class="RailReader2.Views.DocumentView"
             x:DataType="vm:MainWindowViewModel">
    <Panel>
        <!-- Layered PDF viewport with compositor-driven camera. Focusable so a pane click can
             hand keyboard focus to it (nav keys then drive the page, not the pane's list).
             AutomationId gives automation a stable handle; the accessible name and live state
             (page / zoom / rail line text) come from DocumentViewportAutomationPeer. -->
        <v:ViewportPanel Name="Viewport" Focusable="True"
                         a:AutomationProperties.AutomationId="DocumentViewport">
            <!-- PagePanel tracks page dimensions for minimap/scrollbar calculations.
                 No RenderTransform: camera is applied inside each layer's Skia canvas. -->
            <Panel Name="CameraPanel">
                <Panel Name="PagePanel"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
            </Panel>
            <!-- Rendering layers fill the full viewport; each applies the camera
                 transform inside its CompositionCustomVisual handler. -->
            <v:PdfPageLayer Name="PageLayer" />
            <v:SearchHighlightLayer Name="SearchLayer" />
            <v:AnnotationLayer Name="AnnotationLayer" />
            <v:RailOverlayLayer Name="OverlayLayer" />
            <!-- Table freeze-panes: rows above + columns left of the frozen cell, pinned over the page.
                 Above the overlay so the table focus-dim doesn't dim the frozen tiles. -->
            <v:FreezePaneLayer Name="FreezeLayer" />
            <!-- Always-on portal markers (gutter for sources, corner badge for targets) on top. -->
            <v:PortalMarkerLayer Name="PortalMarkerLayer" />
        </v:ViewportPanel>

        <!-- Minimap overlay -->
        <v:MinimapControl Name="Minimap"
                          IsVisible="{Binding ShowMinimap}" />

        <!-- Annotation toolbar overlay (always-on Browse/Select/Copy + Annotate,
             expanding to the tool set when annotation mode is active). While a viewport-placement
             gesture is armed (freeze split, or "start rail here") it dims and stops hit-testing so
             it doesn't block the click that drops the split/point (both can land near the toolbar's
             top-left corner). -->
        <v:ToolBarView Name="ToolBar"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Left"
                       Margin="16,4,0,0"
                       IsVisible="{Binding Tabs.Count}"
                       IsHitTestVisible="{Binding !ViewportPlacementArmed}"
                       Opacity="{Binding ToolBarOpacity}" />

        <!-- Semi-auto scroll parked: a clear bottom-centre "press D" affordance so a stop on an
             equation / table / figure / heading (or a column / page break) never reads as a freeze.
             Non-hit-testable so it never intercepts pan/zoom while you study the parked block. -->
        <Border IsVisible="{Binding AutoScrollParked}"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,28"
                Background="#CC000000" CornerRadius="6" Padding="16,8"
                BoxShadow="0 2 8 0 #40000000"
                IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Parked" FontWeight="Bold" Foreground="#FFAA00" VerticalAlignment="Center" />
                <TextBlock Text="press D or S to continue" Foreground="White" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Scan All overlay: faded viewport + opaque progress card -->
        <Border IsVisible="{Binding IsScanAllActive}"
                Background="#50000000"
                IsHitTestVisible="True">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    CornerRadius="8" Padding="24,16"
                    BoxShadow="0 2 8 0 #40000000">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <!-- IsIndeterminate is gated on visibility on purpose: an indeterminate
                         ProgressBar left attached to the tree (collapsed) keeps running its
                         infinite animation, which holds Avalonia's animation clock open and
                         busy-loops the X11/GLib dispatcher at ~100% CPU. Stop it when hidden. -->
                    <ProgressBar IsIndeterminate="{Binding IsScanAllActive}"
                                 Width="180" Height="4"
                                 Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                    <TextBlock Text="{Binding ScanAllProgress}"
                               FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Press Escape to cancel"
                               Opacity="0.6" FontSize="11"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Border>

        <!-- Frozen-state affordance: an always-obvious chip shown over THIS pane whenever its view has
             a freeze, so unfreezing never requires hunting through the side panel. Per-pane (each
             DocumentView toggles its own from its viewport's freeze state). -->
        <Button Name="FreezeChip" IsVisible="False"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="0,6,12,0" Padding="10,5"
                Background="{DynamicResource SystemControlHighlightAccentBrush}"
                Foreground="White" CornerRadius="6"
                Content="❄ Frozen — Unfreeze"
                ToolTip.Tip="Clear this view's frozen panes">
            <Button.Styles>
                <!-- The default theme swaps in a near-transparent PointerOver background, leaving the
                     white text illegible; keep the chip's own accent background on hover. -->
                <Style Selector="Button:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
                </Style>
            </Button.Styles>
        </Button>

        <!-- Focused-pane affordance: an accent border drawn over the surface (no layout shift,
             never hit-tested). Only made visible by SetFocusedVisual when more than one viewport
             surface is live, so a single pane shows no border. -->
        <Border Name="FocusBorder" IsHitTestVisible="False" BorderThickness="0"
                BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}" />
    </Panel>
</UserControl>
