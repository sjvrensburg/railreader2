<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RailReader2.ViewModels"
             xmlns:v="using:RailReader2.Views"
             xmlns:a="using:Avalonia.Automation"
             x:Class="RailReader2.Views.DocumentView"
             x:DataType="vm:MainWindowViewModel">
    <Panel>
        <!-- Layered PDF viewport with compositor-driven camera. Focusable so a pane click can
             hand keyboard focus to it (nav keys then drive the page, not the pane's list).
             AutomationId gives automation a stable handle; the accessible name and live state
             (page / zoom / rail line text) come from DocumentViewportAutomationPeer. -->
        <v:ViewportPanel Name="Viewport" Focusable="True"
                         a:AutomationProperties.AutomationId="DocumentViewport">
            <!-- PagePanel tracks page dimensions for minimap/scrollbar calculations.
                 No RenderTransform: camera is applied inside each layer's Skia canvas. -->
            <Panel Name="CameraPanel">
                <Panel Name="PagePanel"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
            </Panel>
            <!-- Rendering layers fill the full viewport; each applies the camera
                 transform inside its CompositionCustomVisual handler. -->
            <v:PdfPageLayer Name="PageLayer" />
            <v:SearchHighlightLayer Name="SearchLayer" />
            <v:AnnotationLayer Name="AnnotationLayer" />
            <v:RailOverlayLayer Name="OverlayLayer" />
        </v:ViewportPanel>

        <!-- Minimap overlay -->
        <v:MinimapControl Name="Minimap"
                          IsVisible="{Binding ShowMinimap}" />

        <!-- Annotation toolbar overlay (always-on Browse/Select/Copy + Annotate,
             expanding to the tool set when annotation mode is active) -->
        <v:ToolBarView Name="ToolBar"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Left"
                       Margin="16,4,0,0"
                       IsVisible="{Binding Tabs.Count}" />

        <!-- Scan All overlay: faded viewport + opaque progress card -->
        <Border IsVisible="{Binding IsScanAllActive}"
                Background="#50000000"
                IsHitTestVisible="True">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    CornerRadius="8" Padding="24,16"
                    BoxShadow="0 2 8 0 #40000000">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <ProgressBar IsIndeterminate="True"
                                 Width="180" Height="4"
                                 Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                    <TextBlock Text="{Binding ScanAllProgress}"
                               FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Press Escape to cancel"
                               Opacity="0.6" FontSize="11"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</UserControl>
