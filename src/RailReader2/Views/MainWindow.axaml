<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RailReader2.ViewModels"
        xmlns:v="using:RailReader2.Views"
        xmlns:c="using:RailReader2.Controls"
        x:Class="RailReader2.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="railreader2"
        Width="1200" Height="900"
>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- Menu Bar -->
        <v:MenuBarView DockPanel.Dock="Top" DataContext="{Binding}"
                       IsVisible="{Binding !IsFullScreen}" />

        <!-- Tab Bar (visible in windowed mode, or on hover at top edge in fullscreen) -->
        <v:TabBarView Name="TabBar" DockPanel.Dock="Top" DataContext="{Binding}"
                      IsVisible="{Binding IsTabBarVisible}" />

        <!-- Status Bar (visible in windowed mode, or on hover at bottom edge in fullscreen) -->
        <v:StatusBarView x:Name="StatusBar" DockPanel.Dock="Bottom" DataContext="{Binding}"
                         IsVisible="{Binding IsStatusBarVisible}" />

        <!-- Main Content: resizable sidebar + viewport -->
        <Grid Name="MainGrid" ColumnDefinitions="220,Auto,*">
            <!-- Outline Panel (resizable via GridSplitter) -->
            <v:OutlinePanel Name="OutlinePanel" Grid.Column="0"
                            DataContext="{Binding}"
                            MinWidth="200" MaxWidth="600"
                            IsVisible="{Binding ShowOutline}" />

            <!-- Drag handle to resize sidebar -->
            <GridSplitter Grid.Column="1" Width="4"
                          ResizeDirection="Columns"
                          Background="Transparent"
                          IsVisible="{Binding ShowOutline}" />

            <!-- Content area -->
            <DockPanel Grid.Column="2">
                <v:RailToolBar Name="RailToolBar"
                               DockPanel.Dock="Right"
                               IsVisible="False" />

                <Panel>
                    <!-- Layered PDF viewport with compositor-driven camera -->
                    <v:ViewportPanel Name="Viewport">
                        <!-- PagePanel tracks page dimensions for minimap/scrollbar calculations.
                             No RenderTransform: camera is applied inside each layer's Skia canvas. -->
                        <Panel Name="CameraPanel">
                            <Panel Name="PagePanel"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top" />
                        </Panel>
                        <!-- Rendering layers fill the full viewport; each applies the camera
                             transform inside its CompositionCustomVisual handler. -->
                        <v:PdfPageLayer Name="PageLayer" />
                        <v:SearchHighlightLayer Name="SearchLayer" />
                        <v:AnnotationLayer Name="AnnotationLayer" />
                        <v:RailOverlayLayer Name="OverlayLayer" />
                    </v:ViewportPanel>

                    <!-- Minimap overlay -->
                    <v:MinimapControl Name="Minimap"
                                      IsVisible="{Binding ShowMinimap}" />

                    <!-- Toolbar overlay (Browse/Select/Copy) -->
                    <v:ToolBarView Name="ToolBar"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Left"
                                   Margin="16,4,0,0"
                                   IsVisible="{Binding Tabs.Count}" />

                    <!-- Radial annotation menu (screen-space overlay) -->
                    <Canvas Name="RadialMenuCanvas"
                            IsHitTestVisible="{Binding IsRadialMenuOpen}"
                            IsVisible="{Binding IsRadialMenuOpen}">
                        <c:RadialMenu Name="RadialMenuControl"
                                      Canvas.Left="{Binding RadialMenuX}"
                                      Canvas.Top="{Binding RadialMenuY}" />
                    </Canvas>

                    <!-- Welcome text when no document open -->
                    <TextBlock Name="WelcomeText"
                               Text="Open a PDF file (Ctrl+O)"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="White"
                               IsVisible="{Binding !Tabs.Count}" />

                    <!-- Scan All overlay: faded viewport + opaque progress card -->
                    <Border IsVisible="{Binding IsScanAllActive}"
                            Background="#50000000"
                            IsHitTestVisible="True">
                        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                CornerRadius="8" Padding="24,16"
                                BoxShadow="0 2 8 0 #40000000">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                                <ProgressBar IsIndeterminate="True"
                                             Width="180" Height="4"
                                             Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                                <TextBlock Text="{Binding ScanAllProgress}"
                                           FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Press Escape to cancel"
                                           Opacity="0.6" FontSize="11"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Border>
                </Panel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
