<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RailReader2.ViewModels"
        xmlns:v="using:RailReader2.Views"
        xmlns:c="using:RailReader2.Controls"
        xmlns:a="using:Avalonia.Automation"
        x:Class="RailReader2.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="railreader2"
        Width="1200" Height="900"
>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- Menu Bar -->
        <v:MenuBarView DockPanel.Dock="Top" DataContext="{Binding}"
                       IsVisible="{Binding !IsFullScreen}" />

        <!-- Tab strip with a leading sidebar toggle (shows/hides the side panel and reflects
             its state). Visible in windowed mode, or on hover at the top edge in fullscreen. -->
        <DockPanel DockPanel.Dock="Top" IsVisible="{Binding IsTabBarVisible}"
                   Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <ToggleButton Name="SidebarToggle" Classes="toolBtn borderless" DockPanel.Dock="Left"
                          IsChecked="{Binding ShowOutline, Mode=TwoWay}"
                          VerticalAlignment="Center" Margin="4,0,2,0"
                          ToolTip.Tip="Toggle side panel"
                          a:AutomationProperties.Name="Toggle side panel"
                          a:AutomationProperties.AutomationId="SidebarToggle">
                <c:Icon Data="{StaticResource IconPanelLeft}" />
            </ToggleButton>
            <v:TabBarView Name="TabBar" DataContext="{Binding}" />
        </DockPanel>

        <!-- Status Bar (visible in windowed mode, or on hover at bottom edge in fullscreen) -->
        <v:StatusBarView x:Name="StatusBar" DockPanel.Dock="Bottom" DataContext="{Binding}"
                         IsVisible="{Binding IsStatusBarVisible}" />

        <!-- Main Content: resizable sidebar + viewport -->
        <Grid Name="MainGrid" ColumnDefinitions="220,Auto,*">
            <!-- Outline Panel (resizable via GridSplitter) -->
            <v:OutlinePanel Name="OutlinePanel" Grid.Column="0"
                            DataContext="{Binding}"
                            MinWidth="200" MaxWidth="600"
                            IsVisible="{Binding ShowOutline}" />

            <!-- Drag handle to resize sidebar -->
            <GridSplitter Grid.Column="1" Width="4"
                          ResizeDirection="Columns"
                          Background="Transparent"
                          IsVisible="{Binding ShowOutline}" />

            <!-- Content area -->
            <DockPanel Grid.Column="2">
                <v:RailToolBar Name="RailToolBar"
                               DockPanel.Dock="Right"
                               IsVisible="False" />

                <Panel>
                    <!-- Self-contained PDF viewport (layers + minimap + annotation toolbar
                         + scan-all). Always present (and thus always sized), like the old
                         viewport; renders empty when no document is open. -->
                    <v:DocumentView Name="Document" />

                    <!-- Welcome text overlay when no document open -->
                    <TextBlock Name="WelcomeText"
                               Text="Open a PDF file (Ctrl+O)"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="White"
                               IsVisible="{Binding !Tabs.Count}" />
                </Panel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
