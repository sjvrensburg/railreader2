<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RailReader2.ViewModels"
             xmlns:v="using:RailReader2.Views"
             x:Class="RailReader2.Views.CommentsView"
             x:DataType="vm:MainWindowViewModel">
    <DockPanel>
        <ComboBox Name="CommentFilter" DockPanel.Dock="Top"
                  Margin="4" SelectedIndex="0"
                  HorizontalAlignment="Stretch"
                  SelectionChanged="OnCommentFilterChanged">
            <ComboBoxItem Content="All comments" />
            <ComboBoxItem Content="Reviewer" />
            <ComboBoxItem Content="Yours" />
        </ComboBox>

        <TextBlock Name="CommentEmptyLabel" DockPanel.Dock="Top"
                   Text="No comments in this document."
                   Opacity="0.6" Margin="8" IsVisible="False" />

        <ScrollViewer>
            <ItemsControl Name="CommentEntryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="v:CommentEntryViewModel">
                        <Button Click="OnCommentEntryClick"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Margin="2,1" Padding="6,4">
                            <StackPanel Spacing="2">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right"
                                            Background="{Binding BadgeBackground}"
                                            CornerRadius="3" Padding="5,1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SourceBadge}"
                                                   FontSize="10" Foreground="White" />
                                    </Border>
                                    <TextBlock Text="{Binding TypeLabel}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding DateDisplay}"
                                               FontSize="10" Opacity="0.6" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Author}" FontSize="11" Opacity="0.8"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                                <TextBlock Text="{Binding Body}"
                                           IsVisible="{Binding HasBody}"
                                           TextWrapping="Wrap" MaxLines="3"
                                           TextTrimming="CharacterEllipsis"
                                           Opacity="0.9" Margin="0,1,0,0" />
                                <DockPanel Margin="0,1,0,0">
                                    <TextBlock DockPanel.Dock="Left" Text="Status:"
                                               VerticalAlignment="Center" FontSize="10"
                                               Opacity="0.6" Margin="0,0,4,0" />
                                    <ComboBox ItemsSource="{Binding StateOptions}"
                                              SelectedItem="{Binding State, Mode=OneWay}"
                                              FontSize="11" MinHeight="24" Padding="6,0"
                                              HorizontalAlignment="Left"
                                              SelectionChanged="OnCommentStateChanged" />
                                    <TextBlock Text="{Binding PageDisplay}" DockPanel.Dock="Right"
                                               FontSize="10" Opacity="0.5"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
