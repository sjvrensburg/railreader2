<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RailReader2.ViewModels"
             xmlns:v="using:RailReader2.Views"
             xmlns:c="using:RailReader2.Controls"
             x:Class="RailReader2.Views.OutlinePanel"
             x:DataType="vm:MainWindowViewModel">
    <DockPanel>
        <!-- Close button at the top -->
        <Button DockPanel.Dock="Top"
                HorizontalAlignment="Right"
                Padding="8,2"
                Margin="4,2"
                Opacity="0.7"
                Click="OnClosePanelClick">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <c:Icon Data="{StaticResource IconClose}" />
                <TextBlock Text="Close" VerticalAlignment="Center" />
            </StackPanel>
        </Button>

        <!-- Each tab hosts a self-contained pane view. The selected tab is bound to the
             ViewModel's ActivePane so menu/keyboard pane navigation and (later) docking
             drive the same state. The SidePane enum order matches the tab order. -->
        <TabControl Name="PaneTabs" SelectedIndex="{Binding ActivePaneIndex, Mode=TwoWay}">
            <TabItem Header="Outline"><v:OutlineView /></TabItem>
            <TabItem Header="Bookmarks"><v:BookmarksView /></TabItem>
            <TabItem Header="Index"><v:IndexView /></TabItem>
            <TabItem Header="Search"><v:SearchView /></TabItem>
            <TabItem Header="Comments"><v:CommentsView /></TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
