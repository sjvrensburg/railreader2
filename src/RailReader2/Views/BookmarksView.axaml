<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RailReader2.ViewModels"
             xmlns:m="using:RailReader.Core.Models"
             xmlns:c="using:RailReader2.Controls"
             x:Class="RailReader2.Views.BookmarksView"
             x:DataType="vm:MainWindowViewModel">
    <DockPanel>
        <Button Name="AddBookmarkButton" DockPanel.Dock="Top"
                Content="+ Add Bookmark" Margin="4"
                HorizontalAlignment="Stretch"
                Click="OnAddBookmarkClick" />
        <ScrollViewer>
            <StackPanel>
                <!-- Back to previous location -->
                <Button Name="BackButton"
                        IsVisible="False"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Margin="4,0,4,4" Padding="8,6"
                        FontStyle="Italic" Opacity="0.8"
                        Click="OnBackClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <c:Icon Data="{StaticResource IconBack}" />
                        <TextBlock Text="Back to previous location" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <!-- Use ItemsControl instead of ListBox to avoid SelectionChanged issues -->
                <ItemsControl Name="BookmarkList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="m:BookmarkEntry">
                            <Button Click="OnBookmarkClick"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Margin="2,1" Padding="6,4">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                                        <Button Content="Rename"
                                                Padding="6,3"
                                                ToolTip.Tip="Rename bookmark"
                                                Click="OnRenameBookmarkClick" />
                                        <Button Content="Delete"
                                                Padding="6,3"
                                                ToolTip.Tip="Delete bookmark"
                                                Click="OnDeleteBookmarkClick" />
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding PageDisplay}" FontSize="11" Opacity="0.6" />
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
