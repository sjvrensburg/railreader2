<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RailReader2.Views.PasswordDialog"
        Title="Password Required"
        Width="340" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Click="OnOkClick" />
            <Button Content="Cancel" Width="80" Click="OnCancelClick" />
        </StackPanel>
        <StackPanel Spacing="8">
            <TextBlock x:Name="MessageText" TextWrapping="Wrap"
                       Text="This PDF is password-protected." />
            <TextBox x:Name="PasswordInput" PasswordChar="•"
                     PlaceholderText="Password" />
            <CheckBox x:Name="RevealToggle" Content="Show password"
                      IsCheckedChanged="OnRevealToggled" />
        </StackPanel>
    </DockPanel>
</Window>
