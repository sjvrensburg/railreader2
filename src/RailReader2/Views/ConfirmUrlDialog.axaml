<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RailReader2.Views.ConfirmUrlDialog"
        Title="Open Link"
        Width="450" Height="170"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Open" Width="80" Click="OnOpenClick" />
            <Button Content="Cancel" Width="80" Click="OnCancelClick" />
        </StackPanel>
        <StackPanel Spacing="8">
            <TextBlock Text="Open this link in your browser?" />
            <TextBox x:Name="UrlDisplay" IsReadOnly="True" TextWrapping="Wrap" />
        </StackPanel>
    </DockPanel>
</Window>
